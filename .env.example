# ── Frontend (Vite) ────────────────────────────────────────────────────────────
# Public API base URL. Committed as-is in .env.production (non-secret).
VITE_API_URL=https://api.cercol.team

# ── Backend (FastAPI / Hetzner) ───────────────────────────────────────────────
# PostgreSQL connection string for the Hetzner database.
DATABASE_URL=postgresql://user:password@localhost:5432/cercol

# HS256 secret used to sign and verify JWT access tokens.
JWT_SECRET=replace-with-a-long-random-secret

# Resend transactional email API key (magic-link auth, witness invitations).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Google OAuth 2.0 credentials (for Google sign-in).
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxx

# URLs used in email links and OAuth redirects. Override for local dev.
FRONTEND_URL=https://cercol.team
BACKEND_URL=https://api.cercol.team

# ── Stripe (optional — not yet live) ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
