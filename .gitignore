# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Generated by scripts/generate-sitemap.mjs at build time from live API data
# (runs before `vite build` in `npm run build`/`build:full`). The committed
# copy was only a stale snapshot producing phantom diffs; production serves the
# freshly generated one on every deploy.
public/sitemap.xml

# Claude Code local settings (machine-specific, not shared)
.claude/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Environment variables
.env
.env.local
.env.*.local

# Local secrets dir (developer machine; never committed)
.secrets/

# Cached font files downloaded by scripts/generate_og_image.py.
scripts/.og_fonts/

# Service account keys for cloud providers. Pattern-matched so renames
# or downloads from cloud consoles never land in git accidentally.
# Tracked .json files (locales, package.json, etc.) are explicitly
# whitelisted below this block.
*-service-account*.json
cercol-*.json
gcp-*.json
service-account-*.json

# Allow the .json files that are legitimately tracked in this repo.
# These overrides protect against the broad `cercol-*.json` and
# similar patterns above.
!package.json
!package-lock.json
!.markdownlint.json
!src/locales/*.json
!tests/role-oracle.json
!.claude/launch.json
!api/tests/fixtures/**/*.json

# Build analysis and one-off audit scripts
dist/stats.html
scripts/probe-*.mjs

# RStudio / R session artifacts
.Rhistory
.Rapp.history
.RData
.Ruserdata
*.Rproj.user/
.claude.json
/CLAUDE_*.md
