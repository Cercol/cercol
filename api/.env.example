# Supabase project URL — used to derive the JWKS endpoint for JWT verification
# and for any server-side Supabase calls
SUPABASE_URL=https://your-project.supabase.co

# Supabase service_role key — server-side only, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Set by Railway automatically — do not define manually
# PORT=8000
