# Cercol API environment variables.
# Source of truth for env vars actually loaded by api/*.py.
# Copy to /home/cercol/.env on the Hetzner server. Never commit real values.

# ---- Database ---------------------------------------------------------------
# PostgreSQL DSN consumed by the asyncpg pool in api/main.py.
DATABASE_URL=postgresql://cercol:CHANGEME@127.0.0.1:5432/cercol

# ---- Auth -------------------------------------------------------------------
# JWT_SECRET must be >=32 bytes. Used by api/auth.py for HS256 sign/verify.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace-with-a-long-random-string

# Google OAuth client (single web client; redirect URI must match BACKEND_URL/auth/google/callback).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- URLs -------------------------------------------------------------------
# FRONTEND_URL is embedded in magic links, OAuth redirects and Stripe success/cancel URLs.
FRONTEND_URL=https://cercol.team

# BACKEND_URL is used to build OAuth callback URLs sent to Google.
BACKEND_URL=https://api.cercol.team

# ---- Transactional email ----------------------------------------------------
# Resend API key for magic links and notifications (api/emails.py).
RESEND_API_KEY=

# ---- Payments (Stripe) ------------------------------------------------------
# Test mode keys from dashboard.stripe.com/test/apikeys.
STRIPE_SECRET_KEY=sk_test_
# Webhook signing secret from the dashboard after registering /webhooks/stripe.
STRIPE_WEBHOOK_SECRET=whsec_
# Single price id for the premium tier.
STRIPE_PRICE_ID=price_

# ---- Manual DNS verification scripts (Porkbun) ------------------------------
# Not consumed by the FastAPI app. Used by manual DNS-TXT verification scripts
# (Google Search Console domain ownership, future SEO tooling).
# See docs/ops/runbook.md for the workflow.
PORKBUN_API_KEY=
PORKBUN_SECRET_KEY=
PORKBUN_TITLE=cercol-team
