# Supabase project URL — used to derive the JWKS endpoint and for service-side calls
SUPABASE_URL=https://your-project.supabase.co

# Supabase service_role key — server-side only, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe — test keys from dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...  # from Stripe webhook dashboard after registering endpoint
STRIPE_PRICE_ID=price_...        # create product + price at dashboard.stripe.com/test/products

# Frontend URL (used in success/cancel redirect URLs)
FRONTEND_URL=https://cercol.team

# Set by Railway automatically — do not define manually
# PORT=8000
